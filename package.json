{
  "name": "recall",
  "version": "1.0.0",
  "description": "AI-powered local flashcard generator with spaced repetition",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:electron": "electron-builder install-app-deps && electron .",
    "dev:react": "vite",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ollama": "node scripts/test-ollama.js",
    "test:ollama:quick": "node test-ollama-now.js",
    "demo:workflow": "npx tsx src/examples/completeWorkflowExample.ts",
    "demo:workflow:quick": "npx tsx src/examples/completeWorkflowExample.ts --quick",
    "setup:ollama": "npx tsx src/examples/ollamaIntegrationTest.ts --setup",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "keywords": [
    "flashcards",
    "spaced-repetition",
    "ai",
    "education",
    "electron",
    "recall"
  ],
  "author": "Recall Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7",
    "uuid": "^11.1.0"
  }
}
